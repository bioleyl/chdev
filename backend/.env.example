# =============================================================================
# ChDev Backend Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
# Port the server listens on
PORT=3000

# Environment: 'development', 'production', or 'test'
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (optional — defaults to ./data/chdev.db)
# On Windows, use forward slashes or double backslashes:
#   DB_PATH=C:/Users/You/project/chdev/backend/data/chdev.db
#   DB_PATH=C:\\Users\\You\\project\\chdev\\backend\\data\\chdev.db
# DB_PATH=data/chdev.db

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret key — CHANGE THIS IN PRODUCTION
JWT_SECRET=dev-secret-change-in-production

# JWT expiration time (Node.js ms-durations: '1h', '24h', '7d', etc.)
JWT_EXPIRY=1h
