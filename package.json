{
  "name": "chdev",
  "private": true,
  "type": "module",
  "workspaces": ["common", "backend", "frontend", "electron", "doc"],
  "scripts": {
    "dev": "run-p dev:*",
    "dev:api": "npm --workspace backend run dev",
    "dev:web": "npm --workspace frontend run dev",
    "zdev:electron": "npm --workspace electron run dev",
    "zdev:desktop": "run-p dev:api dev:web dev:electron",
    "build": "npm run build -w common && run-p build:*",
    "build:api": "npm --workspace backend run build",
    "build:web": "npm --workspace frontend run build",
    "zbuild:electron": "npm --workspace electron run build",
    "zpackage:electron": "VITE_API_URL=http://localhost:3000/api npm run build:web && npm run zbuild:electron && npm --workspace electron run package",
    "lint": "biome check --fix",
    "doc:dev": "npm --workspace doc run dev",
    "doc:build": "npm --workspace doc run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "jwt-decode": "^4.0.0"
  }
}
